# Required: Your Google AI API key (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your_google_api_key_here

# Directory where ChromaDB will persist vector data (relative to backend/)
CHROMA_PERSIST_DIR=./chroma_data

# Directory where uploaded PDFs are temporarily stored
UPLOAD_DIR=./temp_uploads

# Comma-separated allowed CORS origins (no trailing slash)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Max upload file size in bytes (default: 20MB)
MAX_UPLOAD_SIZE=20971520
